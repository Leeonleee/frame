{
    "configurations": [
        {
            "name": "Linux",
            "includePath": [
                "${workspaceFolder}/**"
            ],
            "defines": [],
            "compilerPath": "/usr/bin/gcc",
            "cStandard": "c17",
            "cppStandard": "gnu++20",
            "intelliSenseMode": "linux-gcc-x64"
        },
        {
         "name": "Pebble Emery",
         "compilerPath": "${env:HOME}/.pebble-sdk/SDKs/current/toolchain/arm-none-eabi/bin/arm-none-eabi-gcc",
         "includePath": [
           "${workspaceFolder}/**",
           "${workspaceFolder}/build/include",
           "${env:HOME}/.pebble-sdk/SDKs/current/sdk-core/pebble/common/include",
           "${env:HOME}/.pebble-sdk/SDKs/current/sdk-core/pebble/emery/include"
         ],
         "defines": [
           "RELEASE",
           "PBL_PLATFORM_EMERY",
           "PBL_COLOR",
           "PBL_RECT",
           "PBL_MICROPHONE",
           "PBL_SMARTSTRAP",
           "PBL_HEALTH",
           "PBL_SMARTSTRAP_POWER",
           "PBL_COMPASS",
           "PBL_TOUCH",
           "PBL_RGB_BACKLIGHT",
           "PBL_SPEAKER",
           "PBL_DISPLAY_WIDTH=200",
           "PBL_DISPLAY_HEIGHT=228",
           "PBL_SDK_3"
         ],
         "cStandard": "c99",
         "intelliSenseMode": "linux-gcc-arm"
       }
    ],
    "version": 4
}